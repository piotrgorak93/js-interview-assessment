{
  "name": "js-interview-assessment",
  "version": "0.0.0",
  "private": true,
  "repository": "https://github.com/piotrgorak93/js-interview-assessment.git",
  "license": "MIT",
  "author": "Piotr Górak <piotrgorak93@gmail.com>",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "tsc -b && vite build",
    "dev": "vite",
    "lint": "eslint .",
    "lint:fix": "eslint --fix",
    "preview": "vite preview",
    "prepare": "husky",
    "format": "prettier . --write",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "test:browser": "vitest --config=vitest.browser.config.ts"
  },
  "dependencies": {
    "antd": "^6.3.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/browser-preview": "^4.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "playwright": "^1.58.2",
    "prettier": "3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "vitest-browser-react": "^2.1.0"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  }
}
